{
  "name": "soulguru",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:apk": "npm run android:sync && cd android && ./gradlew assembleDebug && cp app/build/outputs/apk/debug/app-debug.apk ../SoulGuru-debug.apk",
    "android:apk:backend": "node scripts/validate-mobile-backend.mjs && npm run android:apk",
    "mobile:check-backend": "node scripts/validate-mobile-backend.mjs",
    "production:check": "node scripts/check-production-readiness.mjs",
    "deployment:smoke": "node scripts/smoke-deployed-backend.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@clerk/backend": "^3.8.3",
    "@sentry/react": "^10.60.0",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "^5.0.0",
    "astronomy-engine": "^2.1.19",
    "lucide-react": "^0.468.0",
    "openai": "^6.44.0",
    "posthog-js": "^1.393.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
